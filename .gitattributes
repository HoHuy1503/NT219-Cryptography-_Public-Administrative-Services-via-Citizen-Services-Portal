* text=auto eol=lf

# Text files used by Linux containers/VM must stay LF-normalized.
*.conf text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.rego text eol=lf
*.sh text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Certificates are tracked as text, but should still stay LF-normalized.
*.crt text eol=lf
*.csr text eol=lf

# Binary artifacts must never be normalized.
*.p12 binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
